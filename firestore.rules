rules_version = '2';

// =============================================================================
// Maridão App — Firestore Security Rules
// =============================================================================
// Fluxos cobertos:
//  1. Cadastro de usuário (client/pro)
//  2. Marketplace: listagem e busca de profissionais ativos
//  3. Negociação às cegas: booking criado com proId=null, qualquer pro
//     autenticado pode ler, propor orçamento e aceitar
//  4. Chat em tempo real: mensagens durante status='chat' acessíveis a
//     qualquer usuário logado (pro procurando pedidos); após aceite, só
//     aos participantes (userId / proId)
//  5. Pagamento via Worker (backend grava arrCodeHash, compCode etc.) e
//     fallback client-side (status payment_pending → payment_confirmed)
//  6. Tracking: pro e cliente atualizam trackStatus sem tocar em campos
//     financeiros
//  7. Notificações: pro cria, cliente lê as próprias
//  8. Avaliações: cliente cria (write-once), qualquer logado lê
//  9. Saques: Worker/admin cria, pro lê os próprios
// =============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ── HELPERS ────────────────────────────────────────────────────────────
    function isSignedIn() { return request.auth != null; }
    function isSelf(uid)  { return isSignedIn() && request.auth.uid == uid; }
    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    function isProOwner(proData) {
      return isSignedIn() && proData.uid == request.auth.uid;
    }
    // Campos que o dono não pode alterar em /users (só admin/backend)
    function onlyClientSafeFields(data) {
      return !data.diff(resource.data).affectedKeys().hasAny([
        'role', 'balance', 'commissionEarned', 'kycVerified', 'suspended'
      ]);
    }

    // ── /users/{uid} ────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read:   if isSelf(uid) || isAdmin();
      allow create: if isSelf(uid)
                    && request.resource.data.role in ['client', 'pro']
                    && !('balance' in request.resource.data);
      allow update: if (isSelf(uid) && onlyClientSafeFields(request.resource.data))
                    || isAdmin();
      allow delete: if isAdmin();
    }

    // ── /professionals/{id} ─────────────────────────────────────────────────
    // Qualquer usuário logado pode listar (marketplace / busca de pedidos).
    // GET individual: apenas profissional ativo, o próprio dono ou admin.
    match /professionals/{id} {
      allow list:   if isSignedIn();
      allow get:    if isSignedIn() && (
                      resource.data.status == 'active'
                      || isProOwner(resource.data)
                      || isAdmin()
                    );
      allow create: if isSignedIn()
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.status in ['pending', 'active']
                    && request.resource.data.docsStatus in ['none', 'pending']
                    && !('balance' in request.resource.data)
                    && !('commissionRate' in request.resource.data);
      allow update: if isAdmin() || (
                      isProOwner(resource.data)
                      && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
                        'status', 'docsStatus', 'balance',
                        'approvedAt', 'approvedBy',
                        'rejectedAt', 'rejectedBy', 'rejectionReason',
                        'commissionRate'
                      ])
                    );
      allow delete: if isAdmin();
    }

    // ── /bookings/{id} ──────────────────────────────────────────────────────
    match /bookings/{id} {

      // GET: participante direto, qualquer logado em fase de negociação, ou admin
      allow get: if isSignedIn() && (
        resource.data.userId == request.auth.uid
        || resource.data.proId == request.auth.uid
        || resource.data.status == 'chat'
        || isAdmin()
      );

      // LIST: qualquer logado (app sempre filtra por userId/proId na query)
      allow list: if isSignedIn();

      // CREATE: apenas o cliente, sem campos de pagamento pré-preenchidos
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && !('compCode'     in request.resource.data)
        && !('arrCodeHash'  in request.resource.data)
        && !('paidAt'       in request.resource.data);

      allow update: if isAdmin()

        // ① Fase de chat aberta (proId ainda null):
        //   qualquer profissional logado pode propor orçamento, aceitar ou declinar.
        //   Campos financeiros protegidos.
        || (
          isSignedIn()
          && resource.data.status == 'chat'
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
            'compCode', 'compCodeHash', 'arrCodeHash', 'paidAt',
            'commission', 'netToPro', 'balance', 'userId'
          ])
        )

        // ② Fallback de pagamento client-side (Worker indisponível / TEST_MODE):
        //   cliente confirma pagamento gravando hashes + status no Firestore.
        || (
          isSignedIn()
          && resource.data.userId == request.auth.uid
          && resource.data.status == 'payment_pending'
          && request.resource.data.status == 'payment_confirmed'
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
            'commission', 'netToPro', 'balance', 'userId', 'proId'
          ])
        )

        // ③ Participantes (cliente ou pro aceito) atualizam campos não-financeiros:
        //   negociação, tracking, status de chegada/conclusão, cancelamento, etc.
        || (
          isSignedIn()
          && (resource.data.userId == request.auth.uid
              || resource.data.proId == request.auth.uid)
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
            'compCode', 'compCodeHash', 'arrCodeHash', 'paidAt',
            'commission', 'netToPro', 'balance'
          ])
        );

      allow delete: if isAdmin();
    }

    // ── /messages/{id} ──────────────────────────────────────────────────────
    // Durante status='chat': qualquer logado pode ler e criar mensagens
    //   (profissional explorando pedidos ainda não atribuídos).
    // Após aceite: apenas userId e proId do booking.
    match /messages/{id} {
      function bk(bookingId) {
        return get(/databases/$(database)/documents/bookings/$(bookingId)).data;
      }
      function isParticipant(bookingId) {
        let b = bk(bookingId);
        return isSignedIn() && (
          b.userId == request.auth.uid
          || b.proId == request.auth.uid
          || b.status == 'chat'
        );
      }

      allow read:   if isAdmin() || (isSignedIn() && isParticipant(resource.data.bookingId));

      allow create: if isSignedIn()
        && request.resource.data.bookingId is string
        && isParticipant(request.resource.data.bookingId)
        && (
          // Mensagem de usuário (cliente)
          (request.resource.data.sender == 'user'
            && request.resource.data.userId == request.auth.uid)
          // Mensagem de profissional
          || (request.resource.data.sender == 'pro'
              && request.resource.data.proId == request.auth.uid)
          // Mensagem de sistema (gerada pelo cliente/pro no front)
          || request.resource.data.sender == 'sys'
        );

      allow update, delete: if isAdmin();
    }

    // ── /notifications/{id} ─────────────────────────────────────────────────
    // Profissional cria notificação para o cliente ao aceitar pedido.
    // Cliente lê apenas as próprias.
    match /notifications/{id} {
      allow read:   if isSignedIn()
                    && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // ── /ratings/{id} ───────────────────────────────────────────────────────
    match /ratings/{id} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn()
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.stars is number
                    && request.resource.data.stars >= 1
                    && request.resource.data.stars <= 5;
      allow update, delete: if isAdmin();
    }

    // ── /favorites/{uid}/... ────────────────────────────────────────────────
    match /favorites/{uid}/{document=**} {
      allow read, write: if isSelf(uid);
    }

    // ── /saques/{id} ────────────────────────────────────────────────────────
    match /saques/{id} {
      allow read:  if isSignedIn()
                   && (resource.data.proId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }

    // ── /admin/{doc=**} ─────────────────────────────────────────────────────
    match /admin/{document=**} {
      allow read, write: if isAdmin();
    }

    // Fallback: nega tudo que não for mapeado acima
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
